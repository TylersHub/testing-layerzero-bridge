{
  "exclude": ["node_modules"],
  "include": ["deploy", "tasks", "test", "scripts", "hardhat.config.ts", "layerzero.config.ts", "hardhat.type.d.ts"],
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  }
}
